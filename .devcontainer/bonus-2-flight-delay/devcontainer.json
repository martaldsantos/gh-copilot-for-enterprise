{
	"name": "Bonus 2 - Flight Delay Predictor",
	"image": "mcr.microsoft.com/devcontainers/python:3.11",
	"features": {
		"ghcr.io/devcontainers/features/node:1": {
			"version": "lts"
		},
		"ghcr.io/devcontainers/features/github-cli:1": {}
	},
	"customizations": {
		"vscode": {
			"extensions": [
				"GitHub.copilot",
				"GitHub.copilot-chat",
				"ms-python.python",
				"ms-python.vscode-pylance",
				"ms-toolsai.jupyter",
				"dbaeumer.vscode-eslint",
				"humao.rest-client"
			]
		}
	},
	"postCreateCommand": "pip install pandas numpy scikit-learn matplotlib seaborn jupyter flask fastapi uvicorn && cd challenges/bonus-2-flight-delay/client && npm install",
	"remoteUser": "vscode"
}
