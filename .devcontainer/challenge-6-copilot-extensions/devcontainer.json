{
	"name": "Challenge 6 - Copilot Extensions (Bonus)",
	"image": "mcr.microsoft.com/devcontainers/base:ubuntu",
	"features": {
		"ghcr.io/devcontainers/features/node:1": {
			"version": "lts"
		},
		"ghcr.io/devcontainers/features/docker-in-docker:2": {},
		"ghcr.io/devcontainers/features/github-cli:1": {}
	},
	"customizations": {
		"vscode": {
			"extensions": [
				"GitHub.copilot",
				"GitHub.copilot-chat",
				"dbaeumer.vscode-eslint",
				"humao.rest-client"
			]
		}
	},
	"postCreateCommand": "cd challenges/challenge-6-copilot-extensions && npm install",
	"remoteUser": "vscode"
}
